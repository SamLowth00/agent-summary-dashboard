# Node environment
NODE_ENV=development

# Port the Express API listens on
PORT=3333

# Allowed CORS origins (comma-separated).
CORS_ORIGIN=http://localhost:4200,http://localhost:4300

# SQLite database file, resolved relative to the process working directory.
DATABASE_STORAGE=./db/database.db

# Base URL for the open-meteo weather API.
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast
